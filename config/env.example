# ─────────────────────────────────────────────
#  Trading RAG — Environment Configuration
# ─────────────────────────────────────────────

# ── LLM Provider (choose one: openai | anthropic | google) ──
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6

# ── API Keys ──
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...
GOOGLE_API_KEY=AIza...

# ── Embeddings ──
# Provider for generating embeddings: openai | local
# "local" uses a lightweight sentence-transformers model (no API key needed)
EMBEDDING_PROVIDER=openai
EMBEDDING_MODEL=text-embedding-3-small

# ── Vector Database (ChromaDB) ──
CHROMA_PERSIST_DIR=./chroma_db
CHROMA_COLLECTION_NAME=trading_prompts

# ── SQLite Metadata DB ──
DATABASE_URL=sqlite:///./trading_rag.db

# ── Retrieval Settings ──
DEFAULT_TOP_K=3
MIN_RELEVANCE_SCORE=0.30

# ── App Settings ──
APP_ENV=development
LOG_LEVEL=INFO
